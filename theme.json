{
	"$schema": "https://schemas.wp.org/wp/6.8/theme.json",
	"version": 3,
	"_comment_architecture": "[CORE structure] The top-level keys, the settings shape, and the templateParts/customTemplates skeleton are the portable scaffold every theme in the line keeps. [SKIN values] The palette, fontFamilies, fontSizes, spacing values, and the whole styles block are design — re-authored per theme. Colophon's own skin is deliberately plain (system fonts, a grayscale palette with one calm accent) so the starter renders honestly without bundling a single font file. The CLI does not auto-merge this file; `colophon doctor` reports drift in the core-owned settings keys instead.",
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"color": {
			"_comment": "[SKIN] Neutral starter palette — a grayscale ink scale, paper grounds, one calm slate accent. defaultPalette off so the editor offers only the theme's tokens. All text/background pairs clear WCAG AA.",
			"defaultPalette": false,
			"defaultGradients": false,
			"defaultDuotone": false,
			"palette": [
				{ "slug": "ink",         "color": "#1a1a1a", "name": "Ink" },
				{ "slug": "ink-soft",    "color": "#3d3d3d", "name": "Ink Soft" },
				{ "slug": "ink-muted",   "color": "#595959", "name": "Ink Muted" },
				{ "slug": "ink-deep",    "color": "#14181c", "name": "Ink Deep" },
				{ "slug": "line",        "color": "#e3e2de", "name": "Hairline" },
				{ "slug": "accent",      "color": "#34597a", "name": "Accent" },
				{ "slug": "accent-soft", "color": "#eaf0f5", "name": "Accent Soft" },
				{ "slug": "paper-soft",  "color": "#f7f6f3", "name": "Paper Soft" },
				{ "slug": "paper",       "color": "#ffffff", "name": "Paper" }
			]
		},
		"typography": {
			"_comment": "[SKIN] System font stacks — no bundled fonts in the starter, so it ships with zero weight and zero third-party calls. A theme built on Colophon adds its own self-hosted OFL families here with @font-face (see ARCHITECTURE.md §5).",
			"fluid": true,
			"customFontSize": false,
			"lineHeight": true,
			"letterSpacing": true,
			"textTransform": true,
			"textDecoration": true,
			"fontFamilies": [
				{
					"name": "Serif",
					"slug": "serif",
					"fontFamily": "Georgia, 'Times New Roman', Times, serif"
				},
				{
					"name": "Sans",
					"slug": "sans",
					"fontFamily": "system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif"
				},
				{
					"name": "Mono",
					"slug": "mono",
					"fontFamily": "ui-monospace, SFMono-Regular, Menlo, Consolas, monospace"
				}
			],
			"fontSizes": [
				{ "name": "Small",    "slug": "sm",      "size": "clamp(1rem, 0.97rem + 0.15vw, 1rem)",    "fluid": { "min": "1rem",    "max": "1rem" } },
				{ "name": "Base",     "slug": "base",    "size": "clamp(1.05rem, 1rem + 0.25vw, 1.2rem)",  "fluid": { "min": "1.05rem", "max": "1.2rem" } },
				{ "name": "Medium",   "slug": "md",      "size": "clamp(1.2rem, 1.1rem + 0.4vw, 1.45rem)", "fluid": { "min": "1.2rem",  "max": "1.45rem" } },
				{ "name": "Large",    "slug": "lg",      "size": "clamp(1.5rem, 1.3rem + 0.9vw, 2rem)",    "fluid": { "min": "1.5rem",  "max": "2rem" } },
				{ "name": "X-Large",  "slug": "xl",      "size": "clamp(2rem, 1.6rem + 1.8vw, 3rem)",      "fluid": { "min": "2rem",    "max": "3rem" } },
				{ "name": "2X-Large", "slug": "2xl",     "size": "clamp(2.5rem, 1.9rem + 3vw, 4.5rem)",    "fluid": { "min": "2.5rem",  "max": "4.5rem" } },
				{ "name": "3X-Large", "slug": "3xl",     "size": "clamp(3rem, 2.2rem + 4vw, 5rem)",        "fluid": { "min": "3rem",    "max": "5rem" } },
				{ "name": "Display",  "slug": "display", "size": "clamp(3rem, 1.8rem + 6vw, 7rem)",        "fluid": { "min": "3rem",    "max": "7rem" } }
			]
		},
		"spacing": {
			"_comment": "[CORE structure / SKIN values] A linear step scale.",
			"customSpacingSize": false,
			"spacingSizes": [
				{ "name": "1",  "slug": "1",  "size": "0.25rem" },
				{ "name": "2",  "slug": "2",  "size": "0.5rem" },
				{ "name": "3",  "slug": "3",  "size": "0.75rem" },
				{ "name": "4",  "slug": "4",  "size": "1rem" },
				{ "name": "5",  "slug": "5",  "size": "1.5rem" },
				{ "name": "6",  "slug": "6",  "size": "2rem" },
				{ "name": "8",  "slug": "8",  "size": "2.5rem" },
				{ "name": "10", "slug": "10", "size": "3rem" },
				{ "name": "12", "slug": "12", "size": "4rem" },
				{ "name": "16", "slug": "16", "size": "6rem" },
				{ "name": "20", "slug": "20", "size": "8rem" }
			]
		},
		"layout": {
			"_comment": "[CORE structure / SKIN values] contentSize = reading measure; wideSize = the band width.",
			"contentSize": "720px",
			"wideSize": "1100px"
		},
		"border": { "color": true, "radius": true, "style": true, "width": true },
		"dimensions": { "minHeight": true, "aspectRatio": true },
		"position": { "sticky": true },
		"blocks": {
			"core/button": { "border": { "radius": false } },
			"core/post-featured-image": { "allowResize": false }
		}
	},
	"styles": {
		"_comment": "[SKIN] Colophon's plain default. A theme built on it replaces this whole block.",
		"color": {
			"background": "var(--wp--preset--color--paper)",
			"text": "var(--wp--preset--color--ink)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--serif)",
			"fontSize": "var(--wp--preset--font-size--base)",
			"lineHeight": "1.7"
		},
		"spacing": {
			"blockGap": "var(--wp--preset--spacing--6)",
			"padding": {
				"left": "var(--wp--preset--spacing--5)",
				"right": "var(--wp--preset--spacing--5)"
			}
		},
		"elements": {
			"h1": {
				"typography": { "fontFamily": "var(--wp--preset--font-family--serif)", "fontSize": "var(--wp--preset--font-size--2xl)", "fontWeight": "700", "lineHeight": "1.12", "letterSpacing": "-0.01em" },
				"color": { "text": "var(--wp--preset--color--ink)" }
			},
			"h2": {
				"typography": { "fontFamily": "var(--wp--preset--font-family--serif)", "fontSize": "var(--wp--preset--font-size--xl)", "fontWeight": "700", "lineHeight": "1.18" },
				"color": { "text": "var(--wp--preset--color--ink)" }
			},
			"h3": {
				"typography": { "fontFamily": "var(--wp--preset--font-family--serif)", "fontSize": "var(--wp--preset--font-size--lg)", "fontWeight": "700", "lineHeight": "1.24" },
				"color": { "text": "var(--wp--preset--color--ink)" }
			},
			"h4": {
				"typography": { "fontFamily": "var(--wp--preset--font-family--sans)", "fontSize": "var(--wp--preset--font-size--md)", "fontWeight": "700" }
			},
			"h5": {
				"typography": { "fontFamily": "var(--wp--preset--font-family--sans)", "fontSize": "var(--wp--preset--font-size--sm)", "fontWeight": "700", "letterSpacing": "0.08em", "textTransform": "uppercase" }
			},
			"h6": {
				"typography": { "fontFamily": "var(--wp--preset--font-family--sans)", "fontSize": "var(--wp--preset--font-size--sm)", "fontWeight": "600", "letterSpacing": "0.12em", "textTransform": "uppercase" },
				"color": { "text": "var(--wp--preset--color--ink-muted)" }
			},
			"link": {
				"color": { "text": "var(--wp--preset--color--accent)" },
				"typography": { "textDecoration": "underline" },
				":hover": { "color": { "text": "var(--wp--preset--color--ink)" } },
				":focus": { "color": { "text": "var(--wp--preset--color--ink)" } }
			},
			"button": {
				"color": { "background": "var(--wp--preset--color--ink)", "text": "var(--wp--preset--color--paper)" },
				"typography": { "fontFamily": "var(--wp--preset--font-family--sans)", "fontSize": "var(--wp--preset--font-size--sm)", "fontWeight": "600", "letterSpacing": "0.03em" },
				"border": { "radius": "0" },
				"spacing": { "padding": { "top": "var(--wp--preset--spacing--4)", "bottom": "var(--wp--preset--spacing--4)", "left": "var(--wp--preset--spacing--6)", "right": "var(--wp--preset--spacing--6)" } },
				":hover": { "color": { "background": "var(--wp--preset--color--accent)" } },
				":focus": { "color": { "background": "var(--wp--preset--color--accent)" } }
			}
		},
		"blocks": {
			"core/post-title": {
				"typography": { "fontFamily": "var(--wp--preset--font-family--serif)", "fontWeight": "700", "lineHeight": "1.14", "textDecoration": "none" },
				"color": { "text": "var(--wp--preset--color--ink)" }
			},
			"core/post-excerpt": {
				"typography": { "fontFamily": "var(--wp--preset--font-family--serif)", "fontSize": "var(--wp--preset--font-size--base)", "lineHeight": "1.7" },
				"color": { "text": "var(--wp--preset--color--ink-soft)" }
			},
			"core/post-date": {
				"typography": { "fontFamily": "var(--wp--preset--font-family--sans)", "fontSize": "var(--wp--preset--font-size--sm)" },
				"color": { "text": "var(--wp--preset--color--ink-muted)" }
			},
			"core/post-terms": {
				"typography": { "fontFamily": "var(--wp--preset--font-family--sans)", "fontSize": "var(--wp--preset--font-size--sm)", "fontWeight": "600", "letterSpacing": "0.1em", "textTransform": "uppercase" },
				"color": { "text": "var(--wp--preset--color--accent)" }
			},
			"core/site-title": {
				"typography": { "fontFamily": "var(--wp--preset--font-family--serif)", "fontSize": "var(--wp--preset--font-size--lg)", "fontWeight": "700", "textDecoration": "none" },
				"color": { "text": "var(--wp--preset--color--ink)" }
			},
			"core/site-tagline": {
				"typography": { "fontFamily": "var(--wp--preset--font-family--sans)", "fontSize": "var(--wp--preset--font-size--sm)", "letterSpacing": "0.08em", "textTransform": "uppercase" },
				"color": { "text": "var(--wp--preset--color--ink-muted)" }
			},
			"core/navigation": {
				"typography": { "fontFamily": "var(--wp--preset--font-family--sans)", "fontSize": "var(--wp--preset--font-size--sm)", "fontWeight": "500", "letterSpacing": "0.04em" }
			},
			"core/separator": {
				"color": { "text": "var(--wp--preset--color--line)" }
			}
		}
	},
	"templateParts": [
		{ "name": "header", "title": "Header", "area": "header" },
		{ "name": "footer", "title": "Footer", "area": "footer" }
	],
	"customTemplates": []
}
