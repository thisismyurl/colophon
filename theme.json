{
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"defaultDuotone": false,
			"palette": [
				{
					"slug": "base-black",
					"color": "#1a1a1a",
					"name": "Base Black"
				},
				{
					"slug": "base-ink",
					"color": "#2e2e2e",
					"name": "Base Ink"
				},
				{
					"slug": "base-mid",
					"color": "#6b6b68",
					"name": "Base Mid"
				},
				{
					"slug": "base-rule",
					"color": "#d6d3cc",
					"name": "Base Rule"
				},
				{
					"slug": "base-ground",
					"color": "#f5f3ee",
					"name": "Base Ground"
				},
				{
					"slug": "base-paper",
					"color": "#ffffff",
					"name": "Base Paper"
				},
				{
					"slug": "base-accent",
					"color": "#1a2f52",
					"name": "Base Accent"
				},
				{
					"slug": "base-accent-tint",
					"color": "#e7ecf4",
					"name": "Base Accent Tint"
				}
			],
			"gradients": []
		},
		"typography": {
			"fluid": true,
			"customFontSize": false,
			"lineHeight": true,
			"letterSpacing": true,
			"textTransform": true,
			"textDecoration": true,
			"fontFamilies": [
				{
					"name": "Serif",
					"slug": "serif",
					"fontFamily": "Georgia, 'Times New Roman', Times, serif"
				},
				{
					"name": "Sans-serif",
					"slug": "sans",
					"fontFamily": "system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif"
				},
				{
					"name": "Monospace",
					"slug": "mono",
					"fontFamily": "ui-monospace, SFMono-Regular, 'SF Mono', Menlo, Consolas, 'Liberation Mono', monospace"
				},
				{
					"name": "EB Garamond",
					"slug": "eb-garamond",
					"fontFamily": "'EB Garamond', Georgia, 'Times New Roman', Times, serif",
					"fontFace": [
						{
							"fontFamily": "EB Garamond",
							"fontStyle": "normal",
							"fontWeight": "400 700",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/eb-garamond/eb-garamond-normal.woff2" ]
						},
						{
							"fontFamily": "EB Garamond",
							"fontStyle": "italic",
							"fontWeight": "400 700",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/eb-garamond/eb-garamond-italic.woff2" ]
						}
					]
				},
				{
					"name": "Spectral",
					"slug": "spectral",
					"fontFamily": "Spectral, Georgia, 'Times New Roman', Times, serif",
					"fontFace": [
						{
							"fontFamily": "Spectral",
							"fontStyle": "normal",
							"fontWeight": "300",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/spectral/spectral-300.woff2" ]
						},
						{
							"fontFamily": "Spectral",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/spectral/spectral-400.woff2" ]
						},
						{
							"fontFamily": "Spectral",
							"fontStyle": "italic",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/spectral/spectral-400-italic.woff2" ]
						},
						{
							"fontFamily": "Spectral",
							"fontStyle": "normal",
							"fontWeight": "600",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/spectral/spectral-600.woff2" ]
						}
					]
				}
			],
			"fontSizes": [
				{
					"name": "2X-Small",
					"slug": "2xs",
					"size": "0.6875rem",
					"fluid": false
				},
				{
					"name": "X-Small",
					"slug": "xs",
					"size": "clamp(0.75rem, 0.72rem + 0.15vw, 0.875rem)",
					"fluid": {
						"min": "0.75rem",
						"max": "0.875rem"
					}
				},
				{
					"name": "Small",
					"slug": "sm",
					"size": "clamp(0.875rem, 0.83rem + 0.22vw, 1rem)",
					"fluid": {
						"min": "0.875rem",
						"max": "1rem"
					}
				},
				{
					"name": "Base",
					"slug": "base",
					"size": "clamp(1rem, 0.96rem + 0.22vw, 1.125rem)",
					"fluid": {
						"min": "1rem",
						"max": "1.125rem"
					}
				},
				{
					"name": "Medium",
					"slug": "md",
					"size": "clamp(1.125rem, 1.07rem + 0.28vw, 1.25rem)",
					"fluid": {
						"min": "1.125rem",
						"max": "1.25rem"
					}
				},
				{
					"name": "Large",
					"slug": "lg",
					"size": "clamp(1.25rem, 1.17rem + 0.42vw, 1.5rem)",
					"fluid": {
						"min": "1.25rem",
						"max": "1.5rem"
					}
				},
				{
					"name": "X-Large",
					"slug": "xl",
					"size": "clamp(1.5rem, 1.37rem + 0.65vw, 1.875rem)",
					"fluid": {
						"min": "1.5rem",
						"max": "1.875rem"
					}
				},
				{
					"name": "2X-Large",
					"slug": "2xl",
					"size": "clamp(1.875rem, 1.67rem + 1.04vw, 2.5rem)",
					"fluid": {
						"min": "1.875rem",
						"max": "2.5rem"
					}
				},
				{
					"name": "3X-Large",
					"slug": "3xl",
					"size": "clamp(2.25rem, 1.93rem + 1.63vw, 3.25rem)",
					"fluid": {
						"min": "2.25rem",
						"max": "3.25rem"
					}
				},
				{
					"name": "Display",
					"slug": "display",
					"size": "clamp(3rem, 2.35rem + 3.26vw, 5rem)",
					"fluid": {
						"min": "3rem",
						"max": "5rem"
					}
				}
			]
		},
		"spacing": {
			"spacingSizes": [
				{ "name": "1", "slug": "1", "size": "0.25rem" },
				{ "name": "2", "slug": "2", "size": "0.5rem" },
				{ "name": "3", "slug": "3", "size": "0.75rem" },
				{ "name": "4", "slug": "4", "size": "1rem" },
				{ "name": "5", "slug": "5", "size": "1.5rem" },
				{ "name": "6", "slug": "6", "size": "2rem" },
				{ "name": "7", "slug": "7", "size": "2.5rem" },
				{ "name": "8", "slug": "8", "size": "3rem" },
				{ "name": "9", "slug": "9", "size": "4rem" },
				{ "name": "10", "slug": "10", "size": "5rem" },
				{ "name": "11", "slug": "11", "size": "6.5rem" },
				{ "name": "12", "slug": "12", "size": "8rem" },
				{ "name": "20", "slug": "20", "size": "12rem" }
			],
			"units": [ "px", "em", "rem", "vh", "vw", "%" ]
		},
		"layout": {
			"contentSize": "720px",
			"wideSize": "1200px"
		},
		"custom": {
			"colophon-light": "#ffffff",
			"colophon-dark": "#1a1a1a",
			"colophon-accent": "#1a2f52"
		},
		"blocks": {
			"core/navigation": {
				"typography": {
					"fontSizes": false
				}
			}
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--base-paper)",
			"text": "var(--wp--preset--color--base-ink)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--sans)",
			"fontSize": "var(--wp--preset--font-size--base)",
			"lineHeight": "1.7"
		},
		"spacing": {
			"blockGap": "var(--wp--preset--spacing--6)"
		},
		"elements": {
			"h1": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--serif)",
					"fontSize": "var(--wp--preset--font-size--3xl)",
					"lineHeight": "1.1",
					"letterSpacing": "-0.02em"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--serif)",
					"fontSize": "var(--wp--preset--font-size--2xl)",
					"lineHeight": "1.2",
					"letterSpacing": "-0.01em"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--serif)",
					"fontSize": "var(--wp--preset--font-size--xl)",
					"lineHeight": "1.3"
				}
			},
			"h4": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--sans)",
					"fontSize": "var(--wp--preset--font-size--md)",
					"fontWeight": "600",
					"lineHeight": "1.4"
				}
			},
			"h5": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--sans)",
					"fontSize": "var(--wp--preset--font-size--sm)",
					"fontWeight": "600",
					"letterSpacing": "0.05em",
					"textTransform": "uppercase"
				}
			},
			"h6": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--sans)",
					"fontSize": "var(--wp--preset--font-size--xs)",
					"fontWeight": "600",
					"letterSpacing": "0.08em",
					"textTransform": "uppercase"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--base-accent)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--base-black)"
					}
				}
			}
		},
		"blocks": {
			"core/code": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--mono)",
					"fontSize": "var(--wp--preset--font-size--sm)"
				}
			},
			"core/site-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--serif)",
					"fontSize": "var(--wp--preset--font-size--lg)",
					"fontWeight": "400"
				}
			},
			"core/post-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--serif)"
				}
			},
			"core/navigation": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--sans)",
					"fontSize": "var(--wp--preset--font-size--sm)"
				}
			},
			"core/separator": {
				"color": {
					"text": "var(--wp--preset--color--base-rule)"
				},
				"border": {
					"color": "var(--wp--preset--color--base-rule)"
				}
			},
			"core/pullquote": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--serif)",
					"fontSize": "var(--wp--preset--font-size--xl)",
					"lineHeight": "1.3"
				},
				"border": {
					"color": "var(--wp--preset--color--base-accent)",
					"width": "3px"
				}
			},
			"core/quote": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--serif)"
				},
				"border": {
					"color": "var(--wp--preset--color--base-rule)",
					"style": "solid",
					"width": "0 0 0 3px"
				}
			}
		}
	},
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		}
	],
	"customTemplates": [
		{
			"name": "page-wide",
			"title": "Page (wide)",
			"postTypes": [ "page" ]
		},
		{
			"name": "page-blank",
			"title": "Page (no header/footer)",
			"postTypes": [ "page" ]
		}
	]
}
